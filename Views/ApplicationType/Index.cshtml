@model IEnumerable<ApplicationType>

@{
    ViewData["Title"] = "Application Type Page";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Application Type List</h2>

        <a asp-controller="ApplicationType" asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> New Application Type
        </a>
    </div>

    @if(Model.Count()>0)
    {
        <table class="table table-striped table-bordered">
        <thead class="table-primary">
            <tr>
                <th>Name</th>
                <th width="200">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var applicationType in Model)
            {
                <tr>
                    <td>@applicationType.Name</td>
                    <td>
                        <a asp-action="Edit"
                           asp-route-id="@applicationType.Id"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        <a asp-action="Details"
                           asp-route-id="@applicationType.Id"
                           class="btn btn-info btn-sm">
                            Details
                        </a>

                        <a asp-action="Delete"
                           asp-route-id="@applicationType.Id"
                           class="btn btn-danger btn-sm">
                            Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    }
    else{
        <p>No application type exists.</p>
    }
</div>