@model Product

@{
    ViewData["Title"] = "Delete Page";
}

<h2>Delete Page</h2>

<form method="post">
   
    <input asp-for="Id" hidden />
    <input asp-for="Image" hidden />
    

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" disabled />
    </div>

    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" rows="5" class="form-control summernote" disabled></textarea>
    </div>

    <div class="mb-3">
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" disabled />
    </div>

    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label"></label>
        <input asp-for="Category.Name" class="form-control" disabled />
    </div>

    <div class="mb-3">
        <label asp-for="ApplicationTypeId" class="form-label"></label>
        <input asp-for="ApplicationType.Name" class="form-control" disabled />
    </div>

    <div class="mb-3">
        Image       

        @if (Model.Id != 0 && !string.IsNullOrEmpty(Model.Image))
        {
            <div class="mt-3">
                <img src="@WC.ImagePath@Model.Image"
                     class="img-thumbnail"
                     style="width:130px;height:130px;object-fit:cover;"  />
            </div>
        }
    </div>

        <button type="submit" class="btn btn-danger">
            Delete
        </button>    

    <a asp-action="Index" class="btn btn-secondary">
        <i class="fas fa-sign-out-alt"></i> Back to List
    </a>

</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function() {
            $('.summmernote').summernote({
                height: 200,
                disabled: true
            });
        });
    </script>
}